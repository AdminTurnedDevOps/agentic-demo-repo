{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["agentgateway", "llm", "cost", "chargeback", "finops"],
  "title": "agentgateway — LLM Cost Chargeback (per gateway)",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "row",
      "title": "Spend rate",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "USD/hr by gateway",
      "description": "Derived from gateway:llm_cost_usd:rate5m (USD/sec) scaled to per-hour.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "gateway:llm_cost_usd:rate5m * 3600",
          "legendFormat": "{{gateway}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "USD/hr by model",
      "description": "Derived from model:llm_cost_usd:rate5m (USD/sec) scaled to per-hour.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "model:llm_cost_usd:rate5m * 3600",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Chargeback",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "barchart",
      "title": "Cumulative spend (last 1h) by gateway",
      "description": "gateway:llm_cost_usd:increase1h — the chargeback figure per team.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": { "orientation": "horizontal" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "gateway:llm_cost_usd:increase1h",
          "legendFormat": "{{gateway}}",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total spend (last 1h, all gateways)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(gateway:llm_cost_usd:increase1h)",
          "instant": true
        }
      ]
    }
  ]
}
