{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["agentgateway", "llm", "cost", "tokens"],
  "title": "agentgateway — Token & Cost Visibility (per gateway)",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "type": "row",
      "title": "Tokens",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Tokens/sec by gateway",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "tps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (gateway, gen_ai_token_type) (rate(agentgateway_gen_ai_client_token_usage_sum[5m]))",
          "legendFormat": "{{gateway}} / {{gen_ai_token_type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens/sec by model",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "tps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (gen_ai_request_model, gen_ai_token_type) (rate(agentgateway_gen_ai_client_token_usage_sum[5m]))",
          "legendFormat": "{{gen_ai_request_model}} / {{gen_ai_token_type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens/sec by provider",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "tps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (gen_ai_system, gen_ai_token_type) (rate(agentgateway_gen_ai_client_token_usage_sum[5m]))",
          "legendFormat": "{{gen_ai_system}} / {{gen_ai_token_type}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total tokens (1h) by gateway",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (gateway) (increase(agentgateway_gen_ai_client_token_usage_sum[1h]))",
          "legendFormat": "{{gateway}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "p95 Time To First Token by gateway + model",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, gateway, gen_ai_request_model) (rate(agentgateway_gen_ai_server_time_to_first_token_bucket[5m])))",
          "legendFormat": "{{gateway}} / {{gen_ai_request_model}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Request Duration by gateway",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, gateway) (rate(agentgateway_gen_ai_server_request_duration_bucket[5m])))",
          "legendFormat": "{{gateway}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Time Per Output Token by gateway",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, gateway) (rate(agentgateway_gen_ai_server_time_per_output_token_bucket[5m])))",
          "legendFormat": "{{gateway}}"
        }
      ]
    }
  ]
}
